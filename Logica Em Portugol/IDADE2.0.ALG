algoritmo "Idade2.0"
var
         a,b,c:inteiro
inicio
      escreva ("Em que ano nos estamos? ")
      leia (a)
      escreva ("Em que ano voce nasceu? ")
      leia (b)
      c<- a-b
      escreva("Em ",a, " voce tera ",c," anos")
      se (c>=18 )entao
           escreval (" e ja sera de maior ")
      senao
           escreva(" e nao sera de maior")
      fimse
fimalgoritmo