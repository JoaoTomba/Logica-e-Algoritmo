algoritmo "ConteAteQndQuiser"
var
   valor,contador,salto: inteiro
inicio
   contador<- 0
   Escreva("Quer contar ate que numero? ")
   leia (valor)
   escreva ("Quer contar de quanto em quanto? ")
   leia (salto)
   enquanto (contador <=valor)faca
      escreval (contador)
      contador  <- contador+salto
   fimenquanto
fimalgoritmo